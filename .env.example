APP_ENV=local
APP_NAME=OPSFoundry API
API_HOST=0.0.0.0
API_PORT=8000

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

POSTGRES_DB=opsfoundry
POSTGRES_USER=opsfoundry
POSTGRES_PASSWORD=opsfoundry
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=

REDIS_URL=redis://redis:6379/0
DUPLICATE_REQUEST_TTL_SECONDS=15
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-vision-service-account.json
OCR_PDF_MAX_PAGES=5
OCR_WARMUP_ON_STARTUP=true
OCR_WARMUP_STRICT=true
STORAGE_ROOT=storage
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=opsfoundry
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
